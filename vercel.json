{
  "buildCommand": "pnpm install && cd artifacts/urja-academy && pnpm run build && cd ../..",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "artifacts/urja-academy/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
