{
  "buildCommand": "pnpm -r --filter @workspace/urja-academy run build && mv artifacts/urja-academy/dist/public ./dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
